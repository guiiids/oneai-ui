# ─── SAGE Completions API ───────────────────────────
SAGE_BASE_URL=https://your-sage-host/v1
SAGE_MODEL=sage

# ─── Azure Key Vault (production) ───────────────────
AZURE_KEYVAULT_URL=
SAGE_KEY_SECRET_NAME=sage-completions-api-key

# ─── Local dev fallback (never set in production) ───
SAGE_COMPLETIONS_API_KEY=your-sage-api-key-here

# ─── OB-4 / Onboard API ─────────────────────────────
OB4_URL=https://your-ob4-host/conversation_complete
OB4_TOKEN=your-ob4-token-here
OB4_EMAIL=your-email@example.com

# ─── Flask ──────────────────────────────────────────
FLASK_SECRET_KEY=change-this-in-production

# ─── Entra ID (Azure AD) — for production SAGE auth ─
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SAGE_RESOURCE_ID=
